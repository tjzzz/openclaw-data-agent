# Environment variables for AI Humanizer
# Copy this file to .env and fill in the values

# Flask secret key (required for session security)
# Generate a secure key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secure-secret-key-change-this-in-production

# Flask environment
FLASK_ENV=development

# Database path (optional, defaults to instance/aigc_humanizer.db)
DATABASE_URL=sqlite:///instance/aigc_humanizer.db

# Payment adapter configuration
PAYMENT_ADAPTER=mock  # mock, wechat, alipay
HUMANIZER_ADAPTER=rule_based  # rule_based, api

# Upload configuration
MAX_CONTENT_LENGTH=10485760  # 10MB in bytes
UPLOAD_FOLDER=uploads/

# Pricing (in Chinese Yuan)
PRICE_PER_1000_WORDS=9.9